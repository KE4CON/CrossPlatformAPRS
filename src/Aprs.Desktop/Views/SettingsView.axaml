<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Aprs.Desktop.Views"
             x:Class="Aprs.Desktop.Views.SettingsView">
  <Grid RowDefinitions="Auto,*"
        Margin="0,10,0,0">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Settings"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <TextBlock Text="Connection and safety settings"
                 Foreground="#526173" />
    </StackPanel>
    <TabControl Grid.Row="1">
      <TabItem Header="First Run">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:FirstRunSetupView DataContext="{Binding FirstRunSetup}" />
        </Border>
      </TabItem>
      <TabItem Header="Station">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:StationSetupView />
        </Border>
      </TabItem>
      <TabItem Header="GPS">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:GpsStatusView DataContext="{Binding GpsStatus}" />
        </Border>
      </TabItem>
      <TabItem Header="Offline Maps">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:OfflineMapManagerView />
        </Border>
      </TabItem>
      <TabItem Header="Direwolf">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:DirewolfProfileView DataContext="{Binding DirewolfProfile}" />
        </Border>
      </TabItem>
      <TabItem Header="Ports">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:PortStatusView DataContext="{Binding PortStatus}" />
        </Border>
      </TabItem>
      <TabItem Header="iGate">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:IGateStatusView DataContext="{Binding IGateStatus}" />
        </Border>
      </TabItem>
      <TabItem Header="Digipeater">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:DigipeaterStatusView DataContext="{Binding DigipeaterStatus}" />
        </Border>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>

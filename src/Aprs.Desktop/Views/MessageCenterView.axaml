<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.MessageCenterView"
             x:DataType="vm:MessageCenterViewModel">
  <Grid RowDefinitions="Auto,*"
        Margin="0,10,0,0">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Messages"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <TextBlock Text="Inbox, outbox, drafts, and compose staging"
                 Foreground="#526173" />
    </StackPanel>

    <Grid Grid.Row="1"
          RowDefinitions="*,Auto"
          RowSpacing="10">
      <TabControl>
        <TabItem Header="Inbox">
          <ListBox ItemsSource="{Binding Inbox}"
                   SelectedItem="{Binding SelectedMessage}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding RemoteStation}"
                             FontWeight="SemiBold"
                             Foreground="#0F172A" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Body}"
                             TextTrimming="CharacterEllipsis"
                             Foreground="#334155" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Timestamp}"
                             Foreground="#64748B"
                             FontSize="11" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Outbox">
          <ListBox ItemsSource="{Binding Outbox}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding RemoteStation}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Body}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Status}"
                             Foreground="#64748B" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Drafts">
          <ListBox ItemsSource="{Binding Drafts}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding RemoteStation}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Body}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Thread">
          <ListBox ItemsSource="{Binding Conversation}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Border BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,3">
                  <StackPanel Spacing="3">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Direction}"
                                 FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Status}"
                                 Foreground="#64748B" />
                    </Grid>
                    <TextBlock Text="{Binding Body}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ValidationSummary}"
                               Foreground="#64748B"
                               FontSize="11"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
      </TabControl>

      <Border Grid.Row="1"
              BorderBrush="#CBD5E1"
              BorderThickness="1"
              CornerRadius="6"
              Background="#F8FAFC"
              Padding="10">
        <Grid ColumnDefinitions="*,*,2*"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="8"
              RowSpacing="6">
          <StackPanel>
            <TextBlock Text="From"
                       FontSize="11"
                       Foreground="#64748B" />
            <TextBox Text="{Binding ComposeLocalStation}" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="To"
                       FontSize="11"
                       Foreground="#64748B" />
            <TextBox Text="{Binding ComposeRecipient}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Message"
                       FontSize="11"
                       Foreground="#64748B" />
            <TextBox Text="{Binding ComposeBody}" />
          </StackPanel>
          <TextBlock Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Text="{Binding ComposeValidationSummary}"
                     Foreground="#64748B"
                     FontSize="11" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>

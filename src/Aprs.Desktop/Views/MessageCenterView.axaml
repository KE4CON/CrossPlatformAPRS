<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Aprs.Desktop.Views.MessageCenterView">
  <Grid RowDefinitions="Auto,*"
        Margin="0,10,0,0">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Messages"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <TextBlock Text="APRS messages and acknowledgements"
                 Foreground="#526173" />
    </StackPanel>
    <Border Grid.Row="1"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="6"
            Background="#F8FAFC">
      <TextBlock Text="Message conversations will appear here."
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Foreground="#526173" />
    </Border>
  </Grid>
</UserControl>

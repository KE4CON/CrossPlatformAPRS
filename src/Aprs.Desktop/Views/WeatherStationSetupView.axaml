<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:views="using:Aprs.Desktop.Views"
             x:Class="Aprs.Desktop.Views.WeatherStationSetupView"
             x:DataType="vm:WeatherStationSetupViewModel">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
          RowSpacing="12">
      <StackPanel Spacing="2">
        <TextBlock Text="Weather Station Setup"
                   FontSize="22"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding SafetySummary}"
                   Foreground="#526173"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Grid Grid.Row="1"
            ColumnDefinitions="280,*"
            ColumnSpacing="12">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="#F8FAFC"
                Padding="10">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="8">
            <TextBlock Text="Weather source"
                       FontWeight="SemiBold" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding AvailableSourceTypes}"
                     SelectedItem="{Binding SelectedSourceType}" />
          </Grid>
        </Border>

        <StackPanel Grid.Column="1"
                    Spacing="10">
          <views:WeatherSourceSettingsView DataContext="{Binding SourceSettings}" />
          <views:WeatherSourceStatusView DataContext="{Binding SourceStatus}" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="2"
            ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="#FFFFFF"
                Padding="10">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="8">
            <TextBlock Text="Current Normalized Observation"
                       FontWeight="SemiBold" />
            <UniformGrid Grid.Row="1"
                         Columns="2">
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="Source"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.SourceName}" />
              </StackPanel>
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Source type"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.SourceType}" />
              </StackPanel>
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="Station/device"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.StationDeviceId}" />
              </StackPanel>
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Timestamp"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.Timestamp}" />
              </StackPanel>
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="Age / state"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.DataAge}" />
                <TextBlock Text="{Binding WeatherDataPreview.StaleWarning}"
                           Foreground="#B45309" />
              </StackPanel>
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Wind"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.Wind}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="Temperature"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.Temperature}" />
              </StackPanel>
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Humidity / pressure"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.Humidity}" />
                <TextBlock Text="{Binding WeatherDataPreview.Pressure}" />
              </StackPanel>
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="Rain"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.Rain}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Solar / UV / lightning"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding WeatherDataPreview.SolarLuminosity}" />
                <TextBlock Text="{Binding WeatherDataPreview.Uv}" />
                <TextBlock Text="{Binding WeatherDataPreview.Lightning}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </UniformGrid>
          </Grid>
        </Border>

        <views:WeatherDiagnosticsView Grid.Column="1"
                                      DataContext="{Binding Diagnostics}" />
      </Grid>

      <Grid Grid.Row="3"
            RowDefinitions="Auto,Auto"
            RowSpacing="8">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
          <TextBlock Text="Packet Preview"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="Refresh Preview"
                  Command="{Binding RefreshPacketPreviewCommand}" />
        </Grid>
        <views:WeatherPacketPreviewView Grid.Row="1"
                                        DataContext="{Binding PacketPreview}" />
      </Grid>

      <Grid Grid.Row="4"
            ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="#FFFFFF"
                Padding="10">
          <Grid RowDefinitions="Auto,Auto,Auto"
                RowSpacing="8">
            <TextBlock Text="Manual Weather Entry"
                       FontWeight="SemiBold" />
            <UniformGrid Grid.Row="1"
                         Columns="2">
              <TextBlock Text="{Binding ManualEntry.SourceName, StringFormat='Source: {0}'}" />
              <TextBlock Text="{Binding ManualEntry.ValidationStatus, StringFormat='Validation: {0}'}" />
              <TextBlock Text="{Binding ManualEntry.TemperatureFahrenheit, StringFormat='Temperature: {0}'}" />
              <TextBlock Text="{Binding ManualEntry.HumidityPercent, StringFormat='Humidity: {0}'}" />
              <TextBlock Text="{Binding ManualEntry.WindDirectionDegrees, StringFormat='Wind direction: {0}'}" />
              <TextBlock Text="{Binding ManualEntry.WindSpeedMph, StringFormat='Wind speed: {0}'}" />
            </UniformGrid>
            <Button Grid.Row="2"
                    HorizontalAlignment="Left"
                    Content="Validate Manual Entry"
                    Command="{Binding ValidateManualEntryCommand}" />
          </Grid>
        </Border>

        <views:WeatherBeaconSettingsView Grid.Column="1"
                                         DataContext="{Binding BeaconSettings}" />
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>

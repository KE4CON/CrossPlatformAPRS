<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.AlertRulesView"
             x:DataType="vm:AlertRulesViewModel">
  <Grid RowDefinitions="Auto,*,*"
        Margin="0,10,0,0"
        RowSpacing="8">
    <Grid ColumnDefinitions="*,Auto,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Alert Rules"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding RuleCountText}"
                   Foreground="#526173" />
      </StackPanel>
      <Button Grid.Column="1"
              Command="{Binding AcknowledgeSelectedCommand}"
              Content="Acknowledge"
              Padding="10,6"
              VerticalAlignment="Center" />
      <Button Grid.Column="2"
              Command="{Binding ClearHistoryCommand}"
              Content="Clear History"
              Padding="10,6"
              VerticalAlignment="Center" />
    </Grid>

    <Border Grid.Row="1"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="6"
            Background="#FFFFFF"
            Padding="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Rules}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#E2E8F0"
                      BorderThickness="0,0,0,1"
                      Padding="0,5">
                <Grid ColumnDefinitions="*,80,100,80,90"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8">
                  <TextBlock Text="{Binding RuleName}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Enabled}" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding AlertType}" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding Severity}" />
                  <TextBlock Grid.Column="4"
                             Text="{Binding TriggerCount, StringFormat='Count {0}'}" />
                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="5"
                             Text="{Binding Threshold, StringFormat='Target/threshold: {0}'}"
                             Foreground="#475569" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="2"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="6"
            Background="#F8FAFC"
            Padding="8">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="6">
        <TextBlock Text="{Binding TriggerCountText, StringFormat='Alert history: {0}'}"
                   FontWeight="SemiBold" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
          <ListBox ItemsSource="{Binding History}"
                   SelectedItem="{Binding SelectedTrigger}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="120,80,110,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="2">
                  <TextBlock Text="{Binding Time}"
                             Foreground="#64748B" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Severity}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Source}" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding Summary}" />
                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="4"
                             Text="{Binding Details}"
                             Foreground="#475569"
                             TextWrapping="Wrap" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>

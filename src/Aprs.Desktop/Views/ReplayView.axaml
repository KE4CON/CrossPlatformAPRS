<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.ReplayView"
             x:DataType="vm:ReplayViewModel">
  <Grid RowDefinitions="Auto,Auto,*"
        Margin="0,10,0,0"
        RowSpacing="8">
    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Replay Mode"
                   FontSize="20"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding TransmitStatusText}"
                   Foreground="#0F766E"
                   FontWeight="SemiBold" />
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Text="{Binding State}"
                 VerticalAlignment="Center"
                 FontWeight="SemiBold"
                 Foreground="#334155" />
    </Grid>

    <Grid Grid.Row="1"
          RowDefinitions="Auto,Auto"
          ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto"
          ColumnSpacing="6"
          RowSpacing="6">
      <TextBox Watermark="Replay file path"
               Text="{Binding SelectedReplayFilePath}" />
      <Button Grid.Column="1"
              Command="{Binding LoadCommand}"
              Content="Load"
              Padding="10,6" />
      <Button Grid.Column="2"
              Command="{Binding PlayCommand}"
              Content="Play"
              Padding="10,6" />
      <Button Grid.Column="3"
              Command="{Binding PauseCommand}"
              Content="Pause"
              Padding="10,6" />
      <Button Grid.Column="4"
              Command="{Binding ResumeCommand}"
              Content="Resume"
              Padding="10,6" />
      <Button Grid.Column="5"
              Command="{Binding StopCommand}"
              Content="Stop"
              Padding="10,6" />

      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">
        <TextBlock Text="Speed" />
        <NumericUpDown Value="{Binding SpeedMultiplier}"
                       Minimum="0.1"
                       Maximum="20"
                       Increment="0.5"
                       Width="80" />
        <CheckBox Content="Loop"
                  IsChecked="{Binding LoopReplay}" />
        <TextBlock Text="{Binding CurrentPositionText}" />
        <TextBlock Text="{Binding CurrentTimestampText}" />
        <TextBlock Text="{Binding ProgressText}" />
      </StackPanel>
      <TextBlock Grid.Row="1"
                 Grid.Column="1"
                 Grid.ColumnSpan="5"
                 Text="{Binding LastError}"
                 Foreground="#B91C1C"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap" />
    </Grid>

    <Border Grid.Row="2"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="6"
            Background="#F8FAFC"
            Padding="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Entries}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}"
                         FontFamily="Menlo,Consolas,monospace"
                         FontSize="12"
                         Foreground="#334155"
                         Margin="0,0,0,4" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>

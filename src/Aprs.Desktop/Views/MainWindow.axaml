<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        xmlns:views="using:Aprs.Desktop.Views"
        x:Class="Aprs.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#18212B"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="10">
        <StackPanel Spacing="1">
          <TextBlock Text="APRS Command"
                     FontSize="19"
                     FontWeight="SemiBold"
                     Foreground="#F8FAFC" />
          <TextBlock Text="APRS station map"
                     FontSize="12"
                     Foreground="#CBD5E1" />
        </StackPanel>
        <Button Grid.Column="1"
                Content="Help"
                Padding="14,6"
                VerticalAlignment="Center"
                Click="Help_Click" />
        <Border Grid.Column="2"
                Background="#1E293B"
                BorderBrush="#64748B"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock Text="APRS-IS Offline"
                     Foreground="#E2E8F0"
                     FontWeight="SemiBold" />
        </Border>
        <Border Grid.Column="3"
                Background="#123B32"
                BorderBrush="#2DD4BF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock Text="TX Disabled"
                     Foreground="#D9FFF7"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Margin="12"
          RowDefinitions="*,190"
          ColumnDefinitions="*,320"
          RowSpacing="10"
          ColumnSpacing="10">
      <views:MapView DataContext="{Binding Map}" />

      <views:StationListView Grid.Column="1"
                             DataContext="{Binding StationList}" />

      <views:PacketMonitorView Grid.Row="1"
                               Grid.Column="0"
                               DataContext="{Binding RawPacketLog}" />

      <TabControl Grid.Column="1"
                  Grid.Row="1">
        <TabItem Header="Messages">
          <views:MessageCenterView DataContext="{Binding MessageCenter}" />
        </TabItem>
        <TabItem Header="Objects">
          <views:ObjectManagerView DataContext="{Binding ObjectManager}" />
        </TabItem>
        <TabItem Header="Weather">
          <views:WeatherView DataContext="{Binding Weather}" />
        </TabItem>
        <TabItem Header="Events">
          <views:DecodedEventLogView DataContext="{Binding DecodedEventLog}" />
        </TabItem>
        <TabItem Header="Event Bus">
          <views:EventMonitorView DataContext="{Binding EventMonitor}" />
        </TabItem>
        <TabItem Header="Replay">
          <views:ReplayView DataContext="{Binding Replay}" />
        </TabItem>
        <TabItem Header="RF Diag">
          <views:RfDiagnosticsView DataContext="{Binding RfDiagnostics}" />
        </TabItem>
        <TabItem Header="Alerts">
          <views:AlertRulesView DataContext="{Binding Alerts}" />
        </TabItem>
        <TabItem Header="Geofence">
          <views:GeofenceEditorView DataContext="{Binding Geofences}" />
        </TabItem>
        <TabItem Header="Sim">
          <views:SimulationView DataContext="{Binding Simulation}" />
        </TabItem>
        <TabItem Header="Training">
          <views:TrainingModeView DataContext="{Binding Training}" />
        </TabItem>
        <TabItem Header="Files">
          <views:FileHooksView DataContext="{Binding FileHooks}" />
        </TabItem>
        <TabItem Header="Settings">
          <views:SettingsView DataContext="{Binding}" />
        </TabItem>
      </TabControl>
    </Grid>

    <views:MainStatusBarView Grid.Row="2" />
  </Grid>
</Window>

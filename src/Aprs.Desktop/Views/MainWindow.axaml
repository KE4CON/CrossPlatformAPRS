<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        xmlns:views="using:Aprs.Desktop.Views"
        x:Class="Aprs.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CrossPlatform APRS"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#18212B"
            Padding="18,14">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock Text="CrossPlatform APRS"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#F8FAFC" />
          <TextBlock Text="Receive-only desktop shell"
                     FontSize="12"
                     Foreground="#CBD5E1" />
        </StackPanel>
        <Border Grid.Column="1"
                Background="#123B32"
                BorderBrush="#2DD4BF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock Text="RF TX Disabled"
                     Foreground="#D9FFF7"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <TabControl Grid.Row="1"
                Padding="12">
      <TabItem Header="Map">
        <views:MapView />
      </TabItem>
      <TabItem Header="Station List">
        <views:StationListView />
      </TabItem>
      <TabItem Header="Raw Packet Monitor">
        <views:PacketMonitorView />
      </TabItem>
      <TabItem Header="Messages">
        <views:MessageCenterView />
      </TabItem>
      <TabItem Header="Objects">
        <views:ObjectManagerView />
      </TabItem>
      <TabItem Header="Weather">
        <views:WeatherView />
      </TabItem>
      <TabItem Header="Settings">
        <views:SettingsView />
      </TabItem>
    </TabControl>

    <views:MainStatusBarView Grid.Row="2" />
  </Grid>
</Window>

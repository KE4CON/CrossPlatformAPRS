<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        xmlns:views="using:Aprs.Desktop.Views"
        x:Class="Aprs.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Window.DataTemplates>
    <DataTemplate DataType="vm:MessageCenterViewModel">
      <views:MessageCenterView />
    </DataTemplate>
    <DataTemplate DataType="vm:ObjectManagerViewModel">
      <views:ObjectManagerView />
    </DataTemplate>
    <DataTemplate DataType="vm:WeatherViewModel">
      <views:WeatherView />
    </DataTemplate>
    <DataTemplate DataType="vm:DecodedEventLogViewModel">
      <views:DecodedEventLogView />
    </DataTemplate>
    <DataTemplate DataType="vm:EventMonitorViewModel">
      <views:EventMonitorView />
    </DataTemplate>
    <DataTemplate DataType="vm:ReplayViewModel">
      <views:ReplayView />
    </DataTemplate>
    <DataTemplate DataType="vm:RfDiagnosticsViewModel">
      <views:RfDiagnosticsView />
    </DataTemplate>
    <DataTemplate DataType="vm:AlertRulesViewModel">
      <views:AlertRulesView />
    </DataTemplate>
    <DataTemplate DataType="vm:GeofenceEditorViewModel">
      <views:GeofenceEditorView />
    </DataTemplate>
    <DataTemplate DataType="vm:SimulationViewModel">
      <views:SimulationView />
    </DataTemplate>
    <DataTemplate DataType="vm:TrainingModeViewModel">
      <views:TrainingModeView />
    </DataTemplate>
    <DataTemplate DataType="vm:FileHooksViewModel">
      <views:FileHooksView />
    </DataTemplate>
    <DataTemplate DataType="vm:FirstRunSetupViewModel">
      <views:FirstRunSetupView />
    </DataTemplate>
  </Window.DataTemplates>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0"
            Background="#18212B"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="10">
        <StackPanel Spacing="1">
          <TextBlock Text="APRS Command"
                     FontSize="19"
                     FontWeight="SemiBold"
                     Foreground="#F8FAFC" />
          <TextBlock Text="APRS station map"
                     FontSize="12"
                     Foreground="#CBD5E1" />
        </StackPanel>
        <Button Grid.Column="1"
                Content="Help"
                Padding="14,6"
                VerticalAlignment="Center"
                Command="{Binding OpenHelpCommand}" />
        <Border Grid.Column="2"
                Background="#1E293B"
                BorderBrush="#64748B"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock Text="APRS-IS Offline"
                     Foreground="#E2E8F0"
                     FontWeight="SemiBold" />
        </Border>
        <Border Grid.Column="3"
                Background="#123B32"
                BorderBrush="#2DD4BF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock Text="TX Disabled"
                     Foreground="#D9FFF7"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Margin="12"
          RowDefinitions="*,240"
          ColumnDefinitions="*,320"
          RowSpacing="10"
          ColumnSpacing="10">
      <views:MapView DataContext="{Binding Map}" />

      <views:StationListView Grid.Column="1"
                             DataContext="{Binding StationList}" />

      <views:PacketMonitorView Grid.Row="1"
                               Grid.Column="0"
                               DataContext="{Binding RawPacketLog}" />

      <Border Grid.Column="1"
              Grid.Row="1"
              Name="FeaturePanel"
              BorderBrush="#CBD5E1"
              BorderThickness="1"
              CornerRadius="6"
              Background="#FFFFFF"
              Padding="8">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="7">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="8">
            <StackPanel>
              <TextBlock Text="{Binding SelectedFeatureName}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="#0F172A" />
              <TextBlock Text="{Binding SelectedFeatureDescription}"
                         FontSize="11"
                         Foreground="#526173"
                         TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="Panel"
                       Foreground="#64748B"
                       FontSize="11"
                       VerticalAlignment="Top" />
          </Grid>

          <Grid Grid.Row="1"
                Name="FeatureButtonGrid"
                RowDefinitions="32,32"
                ColumnDefinitions="*,*,*,*"
                RowSpacing="4"
                ColumnSpacing="4"
                MinHeight="68">
            <Button Grid.Row="0"
                    Grid.Column="0"
                    Content="Messages"
                    Command="{Binding OpenMessagesCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="0"
                    Grid.Column="1"
                    Content="Objects"
                    Command="{Binding OpenObjectsCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Content="Weather"
                    Command="{Binding OpenWeatherCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="0"
                    Grid.Column="3"
                    Content="Events"
                    Command="{Binding OpenEventsCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="1"
                    Grid.Column="0"
                    Content="Event Bus"
                    Command="{Binding OpenEventBusCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="1"
                    Grid.Column="1"
                    Content="Replay"
                    Command="{Binding OpenReplayCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Content="RF Diag"
                    Command="{Binding OpenRfDiagnosticsCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
            <Button Grid.Row="1"
                    Grid.Column="3"
                    Content="Alerts"
                    Command="{Binding OpenAlertsCommand}"
                    FontSize="11"
                    Padding="4,2"
                    HorizontalContentAlignment="Center" />
          </Grid>

          <Border Grid.Row="2"
                  BorderBrush="#E2E8F0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Background="#F8FAFC"
                  Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <ContentControl Content="{Binding SelectedFeatureContent}" />
            </ScrollViewer>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <views:MainStatusBarView Grid.Row="2" />
  </Grid>
</Window>

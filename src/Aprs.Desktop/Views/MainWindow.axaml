<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CrossPlatform APRS"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Background="#18212B"
            Padding="18,14">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock Text="CrossPlatform APRS"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#F8FAFC" />
          <TextBlock Text="Receive-only desktop shell"
                     FontSize="12"
                     Foreground="#CBD5E1" />
        </StackPanel>
        <Border Grid.Column="1"
                Background="#123B32"
                BorderBrush="#2DD4BF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock Text="RF TX Disabled"
                     Foreground="#D9FFF7"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <TabControl Grid.Row="1"
                ItemsSource="{Binding Panes}"
                Padding="12">
      <TabControl.ItemTemplate>
        <DataTemplate DataType="vm:PaneViewModel">
          <TextBlock Text="{Binding Title}" />
        </DataTemplate>
      </TabControl.ItemTemplate>
      <TabControl.ContentTemplate>
        <DataTemplate DataType="vm:PaneViewModel">
          <Grid RowDefinitions="Auto,*"
                Margin="0,10,0,0">
            <StackPanel Grid.Row="0"
                        Margin="0,0,0,12">
              <TextBlock Text="{Binding Title}"
                         FontSize="24"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding Description}"
                         Foreground="#526173" />
            </StackPanel>

            <Border Grid.Row="1"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#F8FAFC">
              <TextBlock Text="{Binding EmptyState}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#526173" />
            </Border>
          </Grid>
        </DataTemplate>
      </TabControl.ContentTemplate>
    </TabControl>
  </Grid>
</Window>

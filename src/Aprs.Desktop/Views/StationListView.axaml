<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.StationListView"
             x:DataType="vm:StationListViewModel">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="8">
    <Grid ColumnDefinitions="*,Auto"
          ColumnSpacing="8">
      <StackPanel Spacing="1">
        <TextBlock Text="Station List"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#0F172A" />
        <TextBlock Text="{Binding RowCount, StringFormat='{}{0} visible stations'}"
                   FontSize="12"
                   Foreground="#526173" />
      </StackPanel>
      <Button Grid.Column="1"
              Padding="8,4"
              Click="SortByLastHeard_Click">
        <TextBlock Text="Recent" />
      </Button>
    </Grid>

    <Grid Grid.Row="1"
          RowDefinitions="Auto,Auto,Auto"
          RowSpacing="6">
      <TextBox Watermark="Search callsign or label"
               Text="{Binding SearchText}"
               TextChanged="SearchTextBox_TextChanged" />

      <Grid Grid.Row="1"
            ColumnDefinitions="*,*"
            ColumnSpacing="6">
        <CheckBox Content="Active only"
                  IsChecked="{Binding ShowActiveOnly}"
                  Checked="ActiveOnlyCheckBox_Changed"
                  Unchecked="ActiveOnlyCheckBox_Changed" />
        <CheckBox Grid.Column="1"
                  Content="Show expired"
                  IsChecked="{Binding ShowExpiredStations}"
                  Checked="ShowExpiredCheckBox_Changed"
                  Unchecked="ShowExpiredCheckBox_Changed" />
      </Grid>

      <ComboBox Grid.Row="2"
                SelectedItem="{Binding SelectedPacketSourceFilter}"
                SelectionChanged="PacketSourceComboBox_SelectionChanged"
                ItemsSource="{Binding PacketSourceFilterOptions}" />
    </Grid>

    <Border Grid.Row="2"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="6"
            Background="#F8FAFC"
            ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#E2E8F0"
                Padding="8,6">
          <Grid ColumnDefinitions="1.2*,1.2*,1.4*,.9*,.9*"
                ColumnSpacing="6">
            <Button Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="SortByCallsign_Click">
              <TextBlock Text="Call"
                         FontWeight="SemiBold"
                         Foreground="#334155" />
            </Button>
            <Button Grid.Column="1"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="SortByDisplayName_Click">
              <TextBlock Text="Name"
                         FontWeight="SemiBold"
                         Foreground="#334155" />
            </Button>
            <TextBlock Grid.Column="2"
                       Text="Symbol"
                       FontWeight="SemiBold"
                       Foreground="#334155" />
            <Button Grid.Column="3"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="SortByAgeState_Click">
              <TextBlock Text="Age"
                         FontWeight="SemiBold"
                         Foreground="#334155" />
            </Button>
            <Button Grid.Column="4"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="SortByPacketSource_Click">
              <TextBlock Text="Src"
                         FontWeight="SemiBold"
                         Foreground="#334155" />
            </Button>
          </Grid>
        </Border>

        <ListBox x:Name="StationRowsListBox"
                 Grid.Row="1"
                 ItemsSource="{Binding Rows}"
                 SelectionChanged="StationRowsListBox_SelectionChanged"
                 Background="#F8FAFC"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:StationListRowViewModel">
              <Border Padding="8,7"
                      BorderBrush="#E2E8F0"
                      BorderThickness="0,0,0,1">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="3">
                  <Grid ColumnDefinitions="1.2*,1.2*,1.4*,.9*,.9*"
                        ColumnSpacing="6">
                    <TextBlock Text="{Binding Callsign}"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplayName}"
                               Foreground="#0F172A"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding SymbolDescription}"
                               Foreground="#475569"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding AgeStateLabel}"
                               Foreground="#475569"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding PacketSourceLabel}"
                               Foreground="#475569"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,*,*,*"
                        ColumnSpacing="6">
                    <TextBlock Text="{Binding LastHeard}"
                               Foreground="#64748B"
                               FontSize="11" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Speed}"
                               Foreground="#64748B"
                               FontSize="11" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Course}"
                               Foreground="#64748B"
                               FontSize="11" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Distance}"
                               Foreground="#64748B"
                               FontSize="11" />
                  </Grid>
                  <TextBlock Grid.Row="2"
                             Text="{Binding Comment}"
                             Foreground="#475569"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Aprs.Desktop.Views.StationSetupView">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
          RowSpacing="12">
      <StackPanel Spacing="2">
        <TextBlock Text="Station Setup"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#0F172A" />
        <TextBlock Text="Local APRS profile. Beaconing is not active yet."
                   Foreground="#526173"
                   FontSize="12" />
      </StackPanel>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,*,*,*"
            RowDefinitions="Auto,Auto,Auto,Auto"
            ColumnSpacing="8"
            RowSpacing="8">
        <StackPanel>
          <TextBlock Text="Callsign"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="N0CALL" />
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="SSID"
                     FontSize="11"
                     Foreground="#64748B" />
          <NumericUpDown Value="7"
                         Minimum="0"
                         Maximum="15" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Latitude"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="39.05830" />
        </StackPanel>
        <StackPanel Grid.Column="3">
          <TextBlock Text="Longitude"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="-84.50830" />
        </StackPanel>

        <StackPanel Grid.Row="1">
          <TextBlock Text="Symbol table"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="/" />
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Grid.Column="1">
          <TextBlock Text="Symbol code"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="-" />
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Grid.Column="2">
          <TextBlock Text="Overlay"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Watermark="Optional" />
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Grid.Column="3">
          <TextBlock Text="PHG"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Watermark="Optional" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2">
          <TextBlock Text="Station comment"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="APRS Command" />
        </StackPanel>
        <StackPanel Grid.Row="2"
                    Grid.Column="2"
                    Grid.ColumnSpan="2">
          <TextBlock Text="Beacon path"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="WIDE1-1,WIDE2-1" />
        </StackPanel>

        <StackPanel Grid.Row="3">
          <TextBlock Text="APRS-IS interval"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="30 min" />
        </StackPanel>
        <StackPanel Grid.Row="3"
                    Grid.Column="1">
          <TextBlock Text="RF interval"
                     FontSize="11"
                     Foreground="#64748B" />
          <TextBox Text="60 min" />
        </StackPanel>
        <CheckBox Grid.Row="3"
                  Grid.Column="2"
                  Content="Fixed station"
                  IsChecked="True"
                  VerticalAlignment="Center" />
        <CheckBox Grid.Row="3"
                  Grid.Column="3"
                  Content="Mobile station"
                  IsChecked="False"
                  VerticalAlignment="Center" />
      </Grid>

      <Border Grid.Row="2"
              Background="#FEF3C7"
              BorderBrush="#F59E0B"
              BorderThickness="1"
              CornerRadius="5"
              Padding="10">
        <StackPanel Spacing="3">
          <TextBlock Text="Transmit safety"
                     FontWeight="SemiBold"
                     Foreground="#92400E" />
          <TextBlock Text="Transmit is disabled by default. APRS-IS transmit and RF transmit are separate settings."
                     Foreground="#92400E"
                     TextWrapping="Wrap" />
          <TextBlock Text="Beaconing is not active in this phase."
                     Foreground="#92400E"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Grid Grid.Row="3"
            ColumnDefinitions="*,*,*"
            ColumnSpacing="8">
        <CheckBox Content="Master transmit enabled"
                  IsChecked="False" />
        <CheckBox Grid.Column="1"
                  Content="APRS-IS transmit enabled"
                  IsChecked="False" />
        <CheckBox Grid.Column="2"
                  Content="RF transmit enabled"
                  IsChecked="False" />
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>

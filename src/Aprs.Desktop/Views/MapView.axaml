<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             x:Class="Aprs.Desktop.Views.MapView"
             x:DataType="vm:MapViewModel">
  <Grid RowDefinitions="Auto,*"
        RowSpacing="8">
    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="10">
      <StackPanel Spacing="1">
        <TextBlock Text="Map"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#0F172A" />
        <TextBlock Text="APRS stations"
                   FontSize="12"
                   Foreground="#526173" />
      </StackPanel>
      <Border Grid.Column="1"
              Background="#EEF6FF"
              BorderBrush="#93C5FD"
              BorderThickness="1"
              CornerRadius="4"
              Padding="8,5"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    Spacing="4">
          <TextBlock Text="{Binding TotalMarkerCount}"
                     FontWeight="SemiBold"
                     Foreground="#1D4ED8" />
          <TextBlock Text="markers"
                     Foreground="#1D4ED8" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="1"
            BorderBrush="#9AB4B1"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">
      <Grid>
        <mapsui:MapControl x:Name="MapControl" />

        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12"
                Background="#F8FAFC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="5"
                Padding="8,6">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock Text="Base map:"
                       VerticalAlignment="Center"
                       Foreground="#475569" />
            <ComboBox x:Name="BaseMapSelector"
                      SelectedIndex="0"
                      MinWidth="170"
                      SelectionChanged="BaseMapSelector_SelectionChanged">
              <ComboBoxItem>OpenStreetMap</ComboBoxItem>
              <ComboBoxItem>USGS Topo</ComboBoxItem>
              <ComboBoxItem>USGS Imagery</ComboBoxItem>
              <ComboBoxItem>USGS Imagery + Topo</ComboBoxItem>
            </ComboBox>
          </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="12"
                Background="#F8FAFC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10,8">
          <StackPanel Spacing="6">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <TextBlock Text="{Binding ObjectPlacementStatus}"
                         Foreground="#475569"
                         TextWrapping="Wrap"
                         MaxWidth="260" />
              <Button Grid.Column="1"
                      Content="Create Object"
                      Command="{Binding BeginCreateObjectCommand}" />
            </Grid>
            <TextBlock Text="Select an object, then click the map to move it locally."
                       FontSize="11"
                       Foreground="#64748B"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border x:Name="EmptySelectionPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="12"
                Background="#F8FAFC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10,8">
          <TextBlock Text="Select a station marker"
                     Foreground="#475569" />
        </Border>

        <Border x:Name="StationDetailsPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="12"
                Background="#F8FAFC"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="5"
                Padding="12"
                MaxWidth="430"
                IsVisible="False">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding SelectedStationDetails.DisplayName}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#0F172A" />
                <TextBlock Text="{Binding SelectedStationDetails.Callsign}"
                           Foreground="#475569"
                           FontSize="12" />
              </StackPanel>
              <Button Grid.Column="1"
                      Padding="8,4"
                      Click="ClearSelectionButton_Click">
                <TextBlock Text="Clear" />
              </Button>
            </Grid>

            <UniformGrid Grid.Row="1"
                         Columns="2"
                         Rows="4">
              <StackPanel Margin="0,0,12,5">
                <TextBlock Text="Symbol"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.SymbolDescription}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,0,5">
                <TextBlock Text="Grid"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.MaidenheadGridSquare}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,12,5">
                <TextBlock Text="Coordinates"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.Coordinates}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,0,5">
                <TextBlock Text="Heard"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.LastHeardAge}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,12,5">
                <TextBlock Text="Speed / Course"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.SpeedCourse}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,0,5">
                <TextBlock Text="Altitude"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.Altitude}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,12,5">
                <TextBlock Text="Source"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.PacketSource}"
                           Foreground="#0F172A" />
              </StackPanel>
              <StackPanel Margin="0,0,0,5">
                <TextBlock Text="Packets"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock Text="{Binding SelectedStationDetails.PacketCount}"
                           Foreground="#0F172A" />
              </StackPanel>
            </UniformGrid>

            <StackPanel Grid.Row="2"
                        Spacing="2">
              <TextBlock Text="Path"
                         FontSize="11"
                         Foreground="#64748B" />
              <TextBlock Text="{Binding SelectedStationDetails.LastPath}"
                         Foreground="#0F172A"
                         TextWrapping="Wrap" />
              <TextBlock Text="Comment"
                         FontSize="11"
                         Foreground="#64748B"
                         Margin="0,5,0,0" />
              <TextBlock Text="{Binding SelectedStationDetails.Comment}"
                         Foreground="#0F172A"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Spacing="2">
              <TextBlock Text="Last Raw Packet"
                         FontSize="11"
                         Foreground="#64748B" />
              <TextBlock Text="{Binding SelectedStationDetails.LastRawPacket}"
                         Foreground="#334155"
                         FontFamily="Consolas,Menlo,Monospace"
                         FontSize="11"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>

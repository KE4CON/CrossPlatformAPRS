<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.PacketMonitorView"
             x:DataType="vm:RawPacketLogViewModel">
  <Grid RowDefinitions="Auto,Auto,*"
        Margin="0,10,0,0"
        RowSpacing="8">
    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Raw Packet Monitor"
                   FontSize="24"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding RowCount, StringFormat='Logged APRS packet lines: {0}'}"
                   Foreground="#526173" />
      </StackPanel>
      <Button Grid.Column="1"
              Command="{Binding ClearLogCommand}"
              Content="Clear"
              Padding="12,6"
              VerticalAlignment="Center" />
    </Grid>

    <Grid Grid.Row="1"
          ColumnDefinitions="2*,*,*,*"
          ColumnSpacing="8">
      <TextBox Watermark="Search packets"
               Text="{Binding SearchText}" />
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding PacketSourceFilterOptions}"
                SelectedItem="{Binding SelectedPacketSourceFilter}" />
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding DirectionFilterOptions}"
                SelectedItem="{Binding SelectedDirectionFilter}" />
      <ComboBox Grid.Column="3"
                ItemsSource="{Binding PacketTypeFilterOptions}"
                SelectedItem="{Binding SelectedPacketTypeFilter}" />
    </Grid>

    <Border Grid.Row="2"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="6"
            Background="#F8FAFC"
            Padding="8">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#E2E8F0"
                      BorderThickness="0,0,0,1"
                      Padding="0,6">
                <Grid ColumnDefinitions="70,95,120,100,95,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="3">
                  <TextBlock Text="{Binding Timestamp}"
                             Foreground="#475569"
                             FontSize="12" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Direction}"
                             Foreground="#0F172A"
                             FontWeight="SemiBold"
                             FontSize="12" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Source}"
                             Foreground="#475569"
                             FontSize="12" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding Callsign}"
                             Foreground="#0F172A"
                             FontWeight="SemiBold"
                             FontSize="12" />
                  <TextBlock Grid.Column="4"
                             Text="{Binding PacketType}"
                             Foreground="#475569"
                             FontSize="12" />
                  <TextBlock Grid.Column="5"
                             Text="{Binding ValidationStatus}"
                             Foreground="#475569"
                             FontSize="12" />
                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="6"
                             Text="{Binding RawPacketText}"
                             Foreground="#0F172A"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="12"
                             TextWrapping="NoWrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.WeatherSourceSettingsView"
             x:DataType="vm:WeatherSourceSettingsViewModel">
  <Border BorderBrush="#CBD5E1"
          BorderThickness="1"
          CornerRadius="6"
          Background="#FFFFFF"
          Padding="12">
    <Grid RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="8">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding SettingsTitle}"
                   FontSize="18"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding SettingsSummary}"
                   Foreground="#526173"
                   TextWrapping="Wrap" />
      </StackPanel>
      <ItemsControl Grid.Row="2"
                    ItemsSource="{Binding Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}"
                       Margin="0,0,0,4"
                       TextWrapping="Wrap" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Grid.Row="3"
                 Text="{Binding CredentialWarning}"
                 Foreground="#B45309"
                 TextWrapping="Wrap" />
    </Grid>
  </Border>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Aprs.Desktop.Views"
        x:Class="Aprs.Desktop.Views.HelpWindow"
        Title="APRS Command Help"
        Width="980"
        Height="720"
        MinWidth="760"
        MinHeight="540">
  <Grid RowDefinitions="*,Auto">
    <views:HelpView />
    <Border Grid.Row="1"
            Background="#F1F5F9"
            BorderBrush="#CBD5E1"
            BorderThickness="0,1,0,0"
            Padding="12">
      <Button Content="Close"
              HorizontalAlignment="Right"
              Padding="14,6"
              Click="Close_Click" />
    </Border>
  </Grid>
</Window>
